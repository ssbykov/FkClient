<!-- res/values/styles.xml -->
<resources>

    <style name="Widget.FK.ProductStatusChip"
        parent="Widget.MaterialComponents.Chip.Entry">

        <item name="chipMinHeight">32dp</item>
        <item name="chipCornerRadius">16dp</item>

        <!-- Обводка -->
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/status_success_text</item>

        <!-- Фон и текст -->
        <item name="chipBackgroundColor">@color/status_success_bg</item>
        <item name="android:textColor">@color/status_success_text</item>

        <!-- Без иконок -->
        <item name="chipIconVisible">false</item>
        <item name="closeIconVisible">false</item>
    </style>

    <style name="Widget.FK.ModuleTypeChip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipIconEnabled">false</item>
        <item name="chipStrokeColor">@color/brand_blue_light</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipBackgroundColor">@android:color/transparent</item>
        <item name="android:textColor">@color/brand_blue</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">24dp</item>
        <item name="chipCornerRadius">12dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="closeIconVisible">false</item>
        <item name="rippleColor">@color/brand_blue</item>
    </style>


</resources>

